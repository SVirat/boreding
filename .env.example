# Copy this file to .env and fill in your actual keys
# cp .env.example .env

# AI provider keys (non-prefixed aliases — used by app.config.js)
GEMINI_API_KEY=
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=

# EXPO_PUBLIC_ prefixed versions (accessible on web via process.env)
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Google Analytics 4 — Measurement Protocol
# Measurement ID from: https://analytics.google.com → Admin → Data Streams
EXPO_PUBLIC_GA_MEASUREMENT_ID=
# API Secret from: GA4 Admin → Data Streams → your stream → Measurement Protocol API secrets → Create
EXPO_PUBLIC_GA_API_SECRET=

# Razorpay — Native SDK + Payment Page
# Payment Page URL used by the app to open the checkout
EXPO_PUBLIC_RAZORPAY_PAYMENT_PAGE_URL=
EXPO_PUBLIC_RAZORPAY_KEY_ID=
